# Renace e-CF — Variables de entorno
# Copiar como .env y completar TODOS los valores antes de deploy
# NUNCA commitear este archivo con valores reales

# --- Dominio y Traefik ---
ECF_DOMAIN=ecf.tu-dominio.do
PORTAL_DOMAIN=portal.ecf.tu-dominio.do
ACME_EMAIL=admin@tu-dominio.do
TRAEFIK_HTTP_PORT=8080
TRAEFIK_HTTPS_PORT=8443

# --- Base de datos ---
DB_PASSWORD=cambia_esto_ahora_32chars_minimo

# --- Redis ---
REDIS_PASSWORD=cambia_esto_redis_password

# --- Vault: llave maestra AES-256 (32 bytes en base64) ---
# Generar con: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
VAULT_MASTER_KEY=

# --- Certificado PSFE (tu cert de cliente ante la DGII, en base64) ---
# Convertir: base64 -w0 mi_psfe_cert.pem
PSFE_CERT_B64=

# --- Llave privada del cert PSFE (en base64) ---
# Convertir: base64 -w0 mi_psfe_key.pem
PSFE_KEY_B64=

# --- CA raiz de la DGII (en base64) — descargar de la DGII ---
DGII_CA_B64=

# --- Operador de plataforma (empresa Renace ante DGII como PSFE) ---
# RNC de la empresa propia que debe certificarse primero antes de onboardear clientes
PLATFORM_OPERATOR_RNC=132842316
# Si true, permite crear clientes sin que el operador haya pasado Probar CerteCF (solo laboratorio)
ALLOW_CLIENT_ONBOARDING=false

# --- Identidad del software ante DGII (debe coincidir con el registro en postulación) ---
DGII_SOFTWARE_NAME=RENECF
# xs:double en postulación DGII (usar 2.5, no 2.5.0)
DGII_SOFTWARE_VERSION=2.5
DGII_SOFTWARE_TIPO=PROPIO

# --- Admin API (para gestión de tenants vía CLI/API) ---
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# --- Métricas (Prometheus scrape) ---
# Generar con: python3 -c "import secrets; print(secrets.token_hex(16))"
METRICS_API_KEY=

# --- CORS (origenes permitidos, separados por coma) ---
ALLOWED_ORIGINS=https://ecf.tu-dominio.do,https://portal.ecf.tu-dominio.do

# --- Ambiente del sistema (CRÍTICO — controla guards de producción) ---
# Valores válidos: eCF (producción DGII), certificacion, simulacion
# En producción DEBE ser "eCF" — activa mTLS obligatorio, vault obligatorio, mock mode bloqueado
ECF_AMBIENTE=certificacion

# --- Rate limiting por tenant (ventana deslizante Redis) ---
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# --- Rate limiting por IP para endpoint público /fe/recepcion/api/ecf ---
IP_RATE_LIMIT_MAX=30
IP_RATE_LIMIT_WINDOW=60

# --- Rotación webhook Odoo (segundos de gracia con secret anterior) ---
WEBHOOK_ROTATION_TTL=900

# --- XSD: poner TRUE solo en TesteCF/CerteCF durante proceso de homologación DGII ---
# NUNCA en producción (ECF_AMBIENTE=eCF lo ignora aunque esté TRUE). Ver: xsd/README.md
SKIP_XSD_VALIDATION=false

# --- SMTP para alertas de vencimiento de certificados ---
SMTP_HOST=smtp.tu-servidor.com
SMTP_PORT=587
SMTP_USER=alertas@renace.tech
SMTP_PASSWORD=
ALERT_FROM_EMAIL=no-reply@renace.tech

# --- Logging ---
# json para producción, text para desarrollo
LOG_FORMAT=text

# Notas de seguridad:
# 1. VAULT_MASTER_KEY: genera una nueva con el comando arriba
#    NUNCA uses la misma en certificacion y produccion
# 2. Rotar VAULT_MASTER_KEY requiere re-cifrar todos los .p12
#    Implementa la rotacion ANTES de ir a produccion
# 3. Hacer backup cifrado de pgdata y de VAULT_MASTER_KEY
#    en lugares SEPARADOS
# 4. DB_PASSWORD debe tener minimo 32 caracteres
# 5. Mantener ALLOWED_ORIGINS restringido a dominios reales
# 6. ADMIN_API_KEY: usa un token largo y único, diferente de las API keys de tenants
