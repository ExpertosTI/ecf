<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_shipment_manager.PosProductGridSales">
        <div class="pos-sales-grid-container d-flex gap-3 w-100 mb-4">
            <!-- Ticket / Líneas Agregadas -->
            <div class="pos-sales-ticket-panel flex-shrink-0 d-flex flex-column" style="width: 350px;">
                <h5 class="panel-title mb-3 d-flex align-items-center gap-2" style="font-weight: 700; color: #1e293b;">
                    <i class="fa fa-shopping-cart text-primary"/>
                    <span>Detalle de Orden</span>
                </h5>
                <div class="pos-sales-ticket-lines flex-grow-1" style="min-height: 0; overflow: hidden;">
                    <t t-if="!list.records.length">
                        <div class="empty-ticket-state d-flex flex-column align-items-center justify-content-center text-muted h-100 p-4" style="border: 2px dashed #e2e8f0; border-radius: 12px; height: 100%;">
                            <i class="fa fa-shopping-basket mb-2" style="font-size: 28px; opacity: 0.4;"/>
                            <span class="text-center" style="font-size: 13px;">Ningún producto en la cotización</span>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="ticket-lines-scroll h-100" style="overflow-y: auto;">
                            <t t-foreach="list.records" t-as="line" t-key="line.id">
                                <div class="ticket-line-item d-flex align-items-center justify-content-between p-3 mb-2" style="background: #f8fafc; border: 1px solid #f1f5f9; border-radius: 12px;">
                                    <div class="line-info flex-grow-1 min-width-0 pe-2">
                                        <div class="line-name fw-bold text-truncate" style="font-size: 13px; color: #1e293b;" t-esc="line.data.product_id ? line.data.product_id[1] : 'Producto'"/>
                                        <div class="line-price text-muted" style="font-size: 11px;">
                                            RD$ <t t-esc="(line.data.price_unit || 0).toFixed(2)"/>
                                        </div>
                                    </div>
                                    <div class="line-actions d-flex align-items-center gap-2">
                                        <button class="btn btn-outline-secondary btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" 
                                                style="width: 26px; height: 26px;"
                                                type="button"
                                                t-on-click="() => this.updateQty(line, -1)">
                                            <i class="fa fa-minus" style="font-size: 10px;"/>
                                        </button>
                                        <span class="line-qty fw-bold" style="min-width: 20px; text-align: center; font-size: 13px;" t-esc="line.data.product_uom_qty"/>
                                        <button class="btn btn-outline-secondary btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" 
                                                style="width: 26px; height: 26px;"
                                                type="button"
                                                t-on-click="() => this.updateQty(line, 1)">
                                            <i class="fa fa-plus" style="font-size: 10px;"/>
                                        </button>
                                        <span class="line-total fw-bold ms-1" style="min-width: 70px; text-align: right; font-size: 13px; color: #0f172a;">
                                            RD$ <t t-esc="(line.data.price_total !== undefined ? line.data.price_total : ((line.data.price_unit || 0) * (line.data.product_uom_qty || 0))).toFixed(2)"/>
                                        </span>
                                        <button class="btn btn-link text-danger p-0 ms-1" type="button" t-on-click="() => this.removeLine(line)">
                                            <i class="fa fa-trash-o" style="font-size: 14px;"/>
                                        </button>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Catálogo de Productos -->
            <div class="pos-sales-catalog-panel flex-grow-1 d-flex flex-column">
                <!-- Filtros y Buscador -->
                <div class="catalog-header d-flex align-items-center gap-3 mb-3">
                    <div class="search-input-wrapper position-relative flex-grow-1">
                        <i class="fa fa-search position-absolute text-muted" style="left: 12px; top: 50%; transform: translateY(-50%);"/>
                        <input type="text" 
                               class="form-control" 
                               placeholder="Buscar producto por nombre..." 
                               style="padding-left: 36px; border-radius: 12px; height: 40px; font-size: 14px;"
                               t-model="state.searchQuery"/>
                    </div>
                    <!-- Select Categorías -->
                    <div class="category-select-wrapper" style="width: 200px;">
                        <select class="form-select" style="border-radius: 12px; height: 40px; font-size: 14px;" t-model="state.selectedCategory">
                            <option value="all">Todas las Categorías</option>
                            <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                                <option t-att-value="cat.id" t-esc="cat.name"/>
                            </t>
                        </select>
                    </div>
                </div>

                <!-- Grid de Productos -->
                <div class="catalog-products-wrapper flex-grow-1" style="overflow-y: auto; min-height: 0;">
                    <t t-if="state.loading">
                        <div class="text-center p-5 text-muted">
                            <i class="fa fa-circle-o-notch fa-spin fa-2x mb-2"/>
                            <div>Cargando productos...</div>
                        </div>
                    </t>
                    <t t-elif="!filteredProducts.length">
                        <div class="text-center p-5 text-muted">
                            <i class="fa fa-exclamation-triangle fa-2x mb-2"/>
                            <div>No se encontraron productos en el catálogo</div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="products-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 12px; padding: 4px;">
                            <t t-foreach="filteredProducts" t-as="product" t-key="product.id">
                                <div class="product-card d-flex flex-column" 
                                     style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; cursor: pointer; transition: all 0.2s ease; position: relative;"
                                     t-on-click="() => this.addProduct(product)">
                                    <div class="product-card-img-wrapper" style="height: 100px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;">
                                        <img t-attf-src="/web/image/product.product/{{product.id}}/image_128" 
                                             style="width: 100%; height: 100%; object-fit: cover;" 
                                             alt="Imagen de producto"
                                             onerror="this.src='/web/static/img/placeholder.png'"/>
                                    </div>
                                    <div class="product-card-body p-2 d-flex flex-column justify-content-between flex-grow-1" style="height: 72px;">
                                        <div class="product-name fw-bold" style="font-size: 11px; color: #334155; line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 26px;" t-esc="product.display_name"/>
                                        <div class="product-price-row d-flex align-items-center justify-content-between mt-1">
                                            <span class="product-price fw-bold" style="font-size: 12px; color: #2563eb;">RD$ <t t-esc="(product.lst_price || 0).toFixed(2)"/></span>
                                            <button class="btn btn-primary btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center" 
                                                    type="button"
                                                    style="width: 22px; height: 22px;">
                                                <i class="fa fa-plus text-white" style="font-size: 10px;"/>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
