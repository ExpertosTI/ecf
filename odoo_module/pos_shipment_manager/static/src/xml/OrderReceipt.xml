<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_shipment_manager.ReceiptHeaderMessenger" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="inside">
            <!-- Modo de Envío y Mensajero -->
            <t t-set="psmShipMode" t-value="(props.data &amp;&amp; props.data.shipment_mode) || (props.data &amp;&amp; props.data.headerData &amp;&amp; props.data.headerData.shipment_mode) || 'none'"/>
            <t t-set="psmMessengerName" t-value="(props.data &amp;&amp; props.data.messenger_name) || (props.data &amp;&amp; props.data.headerData &amp;&amp; props.data.headerData.messenger_name) || ''"/>
            
            <div t-if="psmShipMode and psmShipMode !== 'none'" style="margin-top: 4px; border-top: 1px dashed #000; padding-top: 4px; font-family: 'Courier New', Courier, monospace;">
                <div style="font-weight: bold; font-size: 1.05em; text-align: center; border: 1.5px solid #000; padding: 3px; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.5px;">
                    <t t-if="psmShipMode === 'paid'">★ ENVÍO - PAGADO ★</t>
                    <t t-elif="psmShipMode === 'cod'">★ ENVÍO - CONTRA ENTREGA ★</t>
                </div>
                <div t-if="psmMessengerName" style="margin-top: 2px; font-size: 0.95em;">
                    <span style="font-weight: bold;">MENSAJERO: </span>
                    <span style="font-weight: bold; text-transform: uppercase;"><t t-esc="psmMessengerName"/></span>
                </div>
            </div>
        </xpath>
    </t>
</templates>
