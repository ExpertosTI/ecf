<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Botón de Cotización/Envíos heredado directamente en los botones de control para evitar duplicados de OWL -->
    <t t-name="pos_shipment_manager.QuotationControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('more-btn')]" position="before">
            <button class="btn btn-light btn-lg flex-shrink-0"
                    t-if="!props.showRemainingButtons"
                    t-on-click="onClickQuotationOrder"
                    style="border: 1px solid #e5e7eb; border-radius: 8px; font-weight: 700; padding: 10px 14px;">
                <i class="fa fa-motorcycle me-1"/>
                <span>Envíos</span>
            </button>
        </xpath>
    </t>
</templates>
