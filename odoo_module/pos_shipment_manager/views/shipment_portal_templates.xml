<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Portal del Mensajero (Hoja de Ruta Compacta) -->
    <template id="shipment_confirmation_portal" name="Portal del Mensajero">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&amp;display=swap" rel="stylesheet"/>
                <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
                <style>
                    :root { --primary: #FFD100; --secondary: #000; --bg: #f8fafc; }
                    body { font-family: 'Inter', sans-serif; background: var(--bg); color: #1e293b; margin: 0; padding: 10px; }
                    .waybill-card { max-width: 500px; margin: 0 auto; background: white; border-radius: 25px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
                    .header { background: var(--secondary); color: white; padding: 25px 20px; text-align: center; }
                    .company-logo { height: 50px; max-width: 180px; margin-bottom: 12px; object-fit: contain; display: inline-block; }
                    .header h1 { font-size: 22px; font-weight: 900; margin: 0; letter-spacing: -0.5px; }
                    .header p { opacity: 0.6; font-size: 11px; margin-top: 2px; }
                    .status-line { background: #111; padding: 6px 15px; display: flex; justify-content: center; gap: 8px; }
                    .status-pill { font-size: 9px; font-weight: 900; padding: 3px 10px; border-radius: 99px; text-transform: uppercase; }
                    .pill-primary { background: var(--primary); color: #000; }
                    .pill-pulse { animation: pulse-status 2s infinite; }
                    @keyframes pulse-status { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }
                    .section { padding: 15px 20px; border-bottom: 1px solid #f1f5f9; }
                    .section-title { font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; display: block; }
                    .addr-box { background: #fdfdfd; padding: 15px; border-radius: 15px; border: 1.5px solid #f1f5f9; }
                    .addr-name { font-size: 15px; font-weight: 800; color: #000; margin-bottom: 2px; }
                    .addr-text { font-size: 12px; color: #64748b; line-height: 1.3; }
                    .contact-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
                    .btn-contact { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; padding: 12px 8px; border-radius: 14px; text-decoration: none !important; font-size: 10px; font-weight: 800; background: #fff; border: 1.5px solid #f1f5f9; transition: all 0.2s; }
                    .btn-google { color: #4285F4 !important; }
                    .btn-waze { color: #33CCFF !important; }
                    .btn-whatsapp { color: #25D366 !important; }
                    .btn-contact i { font-size: 20px !important; }
                    .amount-box { background: #f8fafc; border: 1.5px solid #f1f5f9; border-radius: 20px; padding: 15px; text-align: center; margin: 15px 20px; position: relative; }
                    .amount-box::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--primary); }
                    .amount-label { font-size: 10px; font-weight: 800; color: #64748b; text-transform: uppercase; }
                    .amount-value { font-size: 32px; font-weight: 900; color: #000; letter-spacing: -1px; }
                    .actions { padding: 15px 20px; background: #fafafa; }
                    .btn-confirm { background: #10b981; color: white; border: none; width: 100%; border-radius: 16px; padding: 18px; font-weight: 900; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; }
                    .btn-problem { background: transparent; color: #ef4444; border: 1px solid #fee2e2; width: 100%; border-radius: 14px; padding: 12px; font-weight: 700; font-size: 12px; margin-top: 12px; cursor: pointer; }
                    .problem-container { display: none; margin-top: 15px; padding: 15px; background: #fff1f2; border-radius: 18px; border: 1.5px solid #fecaca; }
                    .problem-container label { display: block; font-size: 9px; font-weight: 800; color: #ef4444; text-transform: uppercase; margin-bottom: 6px; }
                    .problem-container select, .problem-container textarea { width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #fecaca; background: white; font-size: 13px; font-family: inherit; margin-bottom: 10px; }
                    .btn-submit-cancel { background: #ef4444; color: white; border: none; width: 100%; border-radius: 12px; padding: 12px; font-weight: 900; font-size: 13px; cursor: pointer; }
                    .footer-brand { text-align: center; margin-top: 25px; font-size: 11px; font-weight: 800; color: #94a3b8; padding-bottom: 30px; }
                    .footer-brand a { color: inherit; text-decoration: none; }
                </style>
            </t>

            <div class="waybill-card">
                <div class="header">
                    <t t-set="company" t-value="shipment.company_id"/>
                    <img t-attf-src="/logo.png?company=#{company.id}" class="company-logo"/>
                    <h1><t t-esc="shipment.name"/></h1>
                    <p>Hoja de Ruta — <t t-esc="today.strftime('%d/%m/%Y') if today else ''"/></p>
                </div>

                <div class="status-line">
                    <span class="status-pill pill-primary pill-pulse">En la Calle</span>
                    <t t-if="shipment.customer_confirmed">
                        <span class="status-pill" style="background: #10b981; color: white;">Cliente Confirmó</span>
                    </t>
                </div>

                <div class="section" style="background: #fffbeb;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span class="section-title" style="margin-bottom: 0; color: #92400e;">Pago Mensajero</span>
                        <span style="font-size: 18px; font-weight: 900; color: #000;">
                            <t t-esc="shipment.shipping_cost" t-options='{"widget": "monetary", "display_currency": shipment.currency_id}'/>
                        </span>
                    </div>
                </div>

                <div class="section">
                    <span class="section-title">Datos de Entrega</span>
                    <div class="addr-box">
                        <div class="addr-name" t-esc="partner.name"/>
                        <div class="addr-text" t-esc="partner.contact_address"/>
                        <div class="contact-grid">
                            <a t-att-href="shipment.nav_google_url" class="btn-contact btn-google">
                                <i class="fa fa-map-marker"/> <span>Maps</span>
                            </a>
                            <a t-att-href="shipment.nav_waze_url" class="btn-contact btn-waze">
                                <i class="fa fa-location-arrow"/> <span>Waze</span>
                            </a>
                            <t t-set="cust_phone" t-value="partner.mobile or partner.phone"/>
                            <t t-if="cust_phone">
                                <t t-set="clean_phone" t-value="''.join(filter(str.isdigit, cust_phone))"/>
                                <t t-if="len(clean_phone) == 10" t-set="clean_phone" t-value="'1' + clean_phone"/>
                                <a t-attf-href="whatsapp://send?phone=#{clean_phone}&amp;text=Hola #{partner.name}, soy el mensajero de #{shipment.company_id.name}, estoy en camino con tu pedido #{shipment.name}." 
                                   class="btn-contact btn-whatsapp">
                                    <i class="fa fa-whatsapp"/> <span>WhatsApp</span>
                                </a>
                            </t>
                        </div>
                    </div>
                </div>

                <div class="section">
                    <span class="section-title">Detalle del Pedido</span>
                    <div style="font-size: 13px;">
                        <t t-set="lines" t-value="order.lines if order else (sale.order_line if sale else [])"/>
                        <t t-foreach="lines" t-as="line">
                            <t t-set="is_service" t-value="line.product_id.type == 'service'"/>
                            <t t-if="not is_service">
                                <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f1f5f9; align-items: center;">
                                    <span style="font-weight: 600; color: #1e293b; max-width: 80%;">
                                        <t t-esc="line.product_id.name"/>
                                    </span>
                                    <span style="font-weight: 900; color: #000; background: #f1f5f9; padding: 2px 8px; border-radius: 6px; font-size: 11px;">
                                        x<t t-esc="int(line.qty if order else line.product_uom_qty)"/>
                                    </span>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>

                <div class="amount-box">
                    <div class="amount-label">Monto a Cobrar</div>
                    <t t-set="mode" t-value="shipment.shipment_mode or (shipment.sale_order_id.shipment_mode if shipment.sale_order_id else 'cod')"/>
                    <t t-set="is_cod" t-value="mode == 'cod'"/>
                    <t t-set="amount_to_collect" t-value="(shipment.order_id.amount_total if shipment.order_id else (shipment.sale_order_id.amount_total if shipment.sale_order_id else 0.0)) if is_cod else (0.0 if mode == 'paid' else (shipment.shipping_charge or 0.0))"/>
                    <div class="amount-value" t-esc="amount_to_collect" t-options='{"widget": "monetary", "display_currency": shipment.currency_id}'/>
                </div>

                <div class="actions">
                    <form action="/pos/shipment/submit_confirmation" method="POST" id="main_form">
                        <input type="hidden" name="token" t-att-value="shipment.secure_token"/>
                        <input type="hidden" name="action" id="form_action" value="confirm"/>
                        <div id="confirm_section">
                            <t t-set="mode" t-value="shipment.shipment_mode or (shipment.sale_order_id.shipment_mode if shipment.sale_order_id else 'cod')"/>
                            <t t-set="is_paid_order" t-value="shipment.is_paid"/>
                            <t t-set="is_cod" t-value="mode == 'cod'"/>
                            <t t-set="is_ready" t-value="is_paid_order or is_cod"/>
                            
                            <div style="margin-bottom: 12px;">
                                <label style="display: block; font-size: 9px; font-weight: 800; color: #94a3b8; text-transform: uppercase; margin-bottom: 6px;">Método de Cobro</label>
                                <select name="payment_method" style="width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid #f1f5f9; font-size: 14px; font-weight: 700; background: white;" t-att-disabled="not is_ready">
                                    <option value="cash">💵 Efectivo</option>
                                    <option value="transfer">🏦 Transferencia</option>
                                </select>
                            </div>

                            <t t-if="is_ready">
                                <button type="submit" class="btn-confirm">
                                    <i class="fa fa-check-circle"/> CONFIRMAR ENTREGA
                                </button>
                            </t>
                            <t t-else="">
                                <button type="button" class="btn-confirm" disabled="disabled" style="background: #e2e8f0; color: #94a3b8; cursor: not-allowed;">
                                    <i class="fa fa-lock"/> ESPERANDO PAGO...
                                </button>
                                <p style="font-size: 10px; color: #94a3b8; text-align: center; margin-top: 8px;">
                                    Este pedido es "Pago al Instante". El botón se activará cuando la tienda confirme el pago.
                                </p>
                            </t>
                            <button type="button" class="btn-problem" onclick="document.getElementById('confirm_section').style.display='none'; document.getElementById('problem_box').style.display='block';">
                                <i class="fa fa-exclamation-triangle"/> Problema / No entregado
                            </button>
                        </div>
                        <div id="problem_box" class="problem-container">
                            <label>Motivo del Inconveniente</label>
                            <select name="cancel_reason">
                                <option value="Cliente Ausente">🏠 Cliente Ausente</option>
                                <option value="Pedido Rechazado">🚫 Pedido Rechazado</option>
                                <option value="Dirección Incorrecta">📍 Dirección Incorrecta</option>
                                <option value="Otro">❓ Otro Motivo</option>
                            </select>
                            <label>Nota del Mensajero</label>
                            <textarea name="messenger_note" rows="3" placeholder="Escribe aquí los detalles..."></textarea>
                            <button type="button" class="btn-submit-cancel" onclick="document.getElementById('form_action').value='cancel'; document.getElementById('main_form').submit();">
                                ENVIAR REPORTE DE INCIDENCIA
                            </button>
                            <button type="button" style="background: transparent; color: #64748b; border: none; width: 100%; margin-top: 10px; font-size: 11px; font-weight: 700;" onclick="document.getElementById('problem_box').style.display='none'; document.getElementById('confirm_section').style.display='block';">
                                Volver atrás
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="footer-brand">
                © <t t-esc="shipment.company_id.name"/> ® <a href="https://renace.tech" target="_blank">RENACE</a>
            </div>
        </t>
    </template>

    <!-- 2. Pantalla de Éxito del Mensajero (NUEVA) -->
    <template id="shipment_messenger_success" name="Entrega Confirmada">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&amp;display=swap" rel="stylesheet"/>
                <style>
                    body { font-family: 'Inter', sans-serif; background: #fff; margin: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; text-align: center; padding: 20px; }
                    .icon { font-size: 80px; margin-bottom: 20px; color: #10b981; }
                    h1 { font-size: 28px; font-weight: 900; margin: 0 0 10px; }
                    p { color: #64748b; font-size: 16px; margin-bottom: 30px; }
                    .btn-back { background: #000; color: #fff; border: none; padding: 15px 30px; border-radius: 12px; font-weight: 800; text-transform: uppercase; cursor: pointer; text-decoration: none; }
                    .footer { margin-top: 50px; font-size: 10px; font-weight: 800; color: #cbd5e1; }
                    .footer a { color: inherit; text-decoration: none; }
                </style>
            </t>
            <div class="icon">✅</div>
            <h1>¡Entrega Confirmada!</h1>
            <p>El pedido <t t-esc="shipment.name"/> ha sido marcado como entregado correctamente.</p>
            <div class="footer">
                © <t t-esc="shipment.company_id.name"/> ® <a href="https://renace.tech" target="_blank">RENACE</a>
            </div>
        </t>
    </template>

    <!-- 3. Éxito al Cancelar -->
    <template id="shipment_cancelled_success">
        <t t-call="web.layout">
            <div style="text-align: center; padding: 80px 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh;">
                <div style="font-size: 60px; margin-bottom: 20px;">⚠️</div>
                <h1 style="font-size: 24px; font-weight: 900;">Reporte Enviado</h1>
                <p style="color: #64748b;">Se ha notificado el inconveniente con este pedido.</p>
                <div style="margin-top: 30px; font-size: 11px; font-weight: 900; color: #94a3b8;">© <t t-esc="shipment.company_id.name"/> ® <a href="https://renace.tech" target="_blank">RENACE</a></div>
            </div>
        </t>
    </template>

    <!-- 4. Página de Seguimiento / Éxito (Cliente) -->
    <template id="shipment_customer_success">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&amp;display=swap" rel="stylesheet"/>
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
                <style>
                    body { font-family: 'Inter', sans-serif; background: #fff; margin: 0; }
                    .tracking-card { max-width: 480px; margin: 0 auto; height: 100vh; display: flex; flex-direction: column; position: relative; }
                    #map-tracking { flex: 1; width: 100%; }
                    .bottom-info { background: white; border-top-left-radius: 35px; border-top-right-radius: 35px; padding: 25px 20px; box-shadow: 0 -10px 40px rgba(0,0,0,0.05); position: absolute; bottom: 0; left: 0; right: 0; z-index: 1000; border: 1px solid #f1f5f9; }
                    .status-pill { background: #dcfce7; color: #16a34a; font-size: 9px; font-weight: 900; padding: 4px 12px; border-radius: 99px; text-transform: uppercase; }
                    .footer-brand { position: absolute; bottom: 15px; left: 0; right: 0; text-align: center; font-size: 10px; font-weight: 800; color: #cbd5e1; z-index: 2000; }
                    .footer-brand a { color: inherit; text-decoration: none; }
                </style>
            </t>
            <div class="tracking-card">
                <t t-if="rating_success">
                    <div style="text-align: center; padding: 60px 20px;">
                        <div style="font-size: 60px; margin-bottom: 20px;">🌟</div>
                        <h1 style="font-size: 26px; font-weight: 900;">¡Gracias!</h1>
                        <p style="color: #64748b; font-size: 14px;">Valoración recibida correctamente.</p>
                        <div style="margin-top: 30px; font-size: 11px; font-weight: 900; color: #94a3b8;">© <t t-esc="shipment.company_id.name"/> ® <a href="https://renace.tech" target="_blank">RENACE</a></div>
                    </div>
                </t>
                <t t-else="">
                    <div id="map-tracking"></div>
                    <div class="bottom-info">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <div>
                                <span class="status-pill">Pedido Confirmado</span>
                                <h2 style="font-size: 22px; font-weight: 900; margin: 5px 0 0;"><t t-esc="shipment.dynamic_eta"/></h2>
                            </div>
                            <div style="background: #000; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 28px; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">🛵</div>
                        </div>
                        <div style="border-top: 1px solid #f1f5f9; padding-top: 20px; display: flex; align-items: center; gap: 12px;">
                            <div style="width: 40px; height: 40px; background: #FFD100; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 900;">
                                <t t-esc="(shipment.messenger_id.name or 'R')[0]"/>
                            </div>
                            <div style="flex: 1;">
                                <div style="font-size: 14px; font-weight: 800; color: #000;" t-esc="shipment.messenger_id.name or 'Mensajero en Camino'"/>
                                <div style="font-size: 11px; color: #94a3b8;"><t t-esc="shipment.name"/></div>
                            </div>
                        </div>
                    </div>
                    <div class="footer-brand">© <t t-esc="shipment.company_id.name"/> ® <a href="https://renace.tech" target="_blank">RENACE</a></div>
                    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                    <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            const lat = <t t-esc="shipment.partner_id.partner_latitude or 18.4619"/>;
                            const lon = <t t-esc="shipment.partner_id.partner_longitude or -69.9366"/>;
                            const map = L.map('map-tracking', { zoomControl: false, attributionControl: false }).setView([lat, lon], 15);
                            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
                            const motoIcon = L.divIcon({ html: '&lt;div style="font-size: 30px;"&gt;🛵&lt;/div&gt;', iconSize: [30, 30], iconAnchor: [15, 15] });
                            L.marker([lat + 0.002, lon + 0.002], { icon: motoIcon }).addTo(map);
                            L.marker([lat, lon]).addTo(map);

                            // Poller para Auto-Refresh (Renquitec Elite)
                            const currentToken = "<t t-esc='shipment.customer_token or shipment.access_token'/>";
                            const currentState = "<t t-esc='shipment.state'/>";
                            
                            setInterval(async () => {
                                try {
                                    const response = await fetch('/pos/shipment/status_json/' + currentToken, {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ params: {} })
                                    });
                                    const result = await response.json();
                                    if (result.result &amp;&amp; result.result.state !== currentState) {
                                        window.location.reload(); // Recargar si cambia el estado (ej: entregado)
                                    }
                                } catch (e) { console.error("Poll error", e); }
                            }, 20000); // Cada 20 segundos
                        });
                    </script>
                </t>
            </div>
        </t>
    </template>
</odoo>
