<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_pos_messenger" model="ir.actions.act_window">
        <field name="name">Mensajeros</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_users_tree_messenger')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_users_form_messenger_simple')})]"/>
        <field name="domain">[('is_messenger', '=', True)]</field>
        <field name="context">{'default_is_messenger': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea un nuevo mensajero aquí.</p>
        </field>
    </record>

    <menuitem id="menu_pos_shipment_root" name="Envíos POS" parent="point_of_sale.menu_point_root" sequence="15"/>
    <menuitem id="menu_pos_shipment_dashboard" name="Tablero de Envíos" parent="menu_pos_shipment_root" action="action_pos_shipment_dashboard" sequence="10"/>
    <menuitem id="menu_pos_shipment_management" name="Gestión de Envíos" parent="menu_pos_shipment_root" action="action_pos_shipment" sequence="20"/>
    <menuitem id="menu_pos_messenger" name="Mensajeros" parent="menu_pos_shipment_root" action="action_pos_messenger" sequence="30"/>
</odoo>
