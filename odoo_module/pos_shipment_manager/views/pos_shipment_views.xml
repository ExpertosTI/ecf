<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Server Actions for State Changes -->
    <record id="action_mark_street" model="ir.actions.server">
        <field name="name">Enviar a la Calle</field>
        <field name="model_id" ref="model_pos_shipment"/>
        <field name="binding_model_id" ref="model_pos_shipment"/>
        <field name="state">code</field>
        <field name="code">
for record in records:
    record.write({'state': 'street', 'date_processed': records.env.cr.now()})
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_pos_shipment_tree" model="ir.ui.view">
        <field name="name">pos.shipment.list</field>
        <field name="model">pos.shipment</field>
        <field name="arch" type="xml">
            <list string="Envíos POS" decoration-info="state == 'street'" decoration-success="state == 'delivered'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="messenger_id"/>
                <field name="distance_km"/>
                <field name="shipping_charge"/>
                <field name="date_invoiced"/>
                <field name="state" widget="badge" decoration-info="state == 'street'" decoration-success="state == 'delivered'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_pos_shipment_form" model="ir.ui.view">
        <field name="name">pos.shipment.form</field>
        <field name="model">pos.shipment</field>
        <field name="arch" type="xml">
            <form string="Envío POS">
                <header>
                    <button name="action_open_share_wizard" string="📤 Compartir Links" type="object" class="btn-primary"
                            help="Copia o envía los links al mensajero y cliente"/>
                    <button name="action_settle_cash" string="Liquidar Entrega" type="object" class="oe_highlight btn-warning" invisible="state != 'delivered'" confirm="¿Confirma que ha recibido el efectivo de este envío?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,street,delivered,settled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_related_order" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Pedido POS</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Información del Pedido">
                            <field name="order_id"/>
                            <field name="partner_id"/>
                            <field name="shipment_mode" widget="radio" options="{'horizontal': true}"/>
                            <field name="date_invoiced"/>
                            <field name="secure_token" groups="base.group_no_one"/>
                        </group>
                        <group string="Logística">
                            <field name="messenger_id"/>
                            <field name="date_processed"/>
                            <field name="date_delivered"/>
                        </group>
                    </group>
                    <group string="Tarifas y Distancia">
                        <group>
                            <label for="distance_km"/>
                            <div class="o_row">
                                <field name="distance_km"/>
                                <span> KM</span>
                            </div>
                            <field name="shipping_charge" widget="monetary"/>
                            <field name="shipping_cost" widget="monetary"/>
                        </group>
                        <group string="Links de Portal">
                        <label for="messenger_portal_url" string="🛵 Link Mensajero"/>
                        <div class="o_row">
                            <field name="messenger_portal_url" widget="CopyClipboardChar" readonly="1"/>
                        </div>
                        <label for="customer_portal_url" string="👤 Link Cliente"/>
                        <div class="o_row">
                            <field name="customer_portal_url" widget="CopyClipboardChar" readonly="1"/>
                            <field name="customer_confirmed" widget="boolean_toggle" readonly="1"/>
                        </div>
                        <field name="customer_note" readonly="1" invisible="not customer_confirmed"/>
                    </group>
                    </group>
                    <notebook>
                        <page string="Feedback de Entrega" name="feedback">
                            <group>
                                <group string="Calificación del Cliente">
                                    <field name="customer_rating" widget="priority"/>
                                    <field name="customer_rating_note"/>
                                </group>
                                <group string="Calificación de la Tienda">
                                    <field name="vendor_rating" widget="priority"/>
                                    <field name="vendor_rating_note"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notas Messenger" name="messenger_notes" invisible="state != 'delivered'">
                             <group>
                                <field name="payment_method_confirmed"/>
                                <field name="messenger_note"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_pos_shipment_kanban" model="ir.ui.view">
        <field name="name">pos.shipment.kanban</field>
        <field name="model">pos.shipment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="messenger_id"/>
                <field name="shipping_charge"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <div><i class="fa fa-user me-1"/> <t t-esc="record.partner_id.value"/></div>
                            <div><i class="fa fa-motorcycle me-1"/> <t t-esc="record.messenger_id.value"/></div>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <field name="shipping_charge" widget="monetary"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_pos_shipment" model="ir.actions.act_window">
        <field name="name">Gestión de Envíos</field>
        <field name="res_model">pos.shipment</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Administra tus envíos aquí.</p>
        </field>
    </record>

    <!-- DASHBOARD CLIENT ACTION -->
    <record id="action_pos_shipment_dashboard" model="ir.actions.client">
        <field name="name">El Pendei - Tablero de Envíos</field>
        <field name="tag">pos_shipment_dashboard</field>
    </record>
</odoo>
