<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-company Rule for POS Shipment -->
        <record id="pos_shipment_comp_rule" model="ir.rule">
            <field name="name">POS Shipment Multi-company</field>
            <field name="model_id" ref="model_pos_shipment"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
    </data>
</odoo>
