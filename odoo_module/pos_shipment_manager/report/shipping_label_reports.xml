<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_shipping_label" model="ir.actions.report">
        <field name="name">Etiqueta de Envío</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_shipment_manager.report_shipping_label_template</field>
        <field name="report_file">pos_shipment_manager.report_shipping_label</field>
        <field name="print_report_name">'Etiqueta - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_shipping_label_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="doc">
                <t t-set="shipment" t-value="doc.shipment_id"/>
                <t t-set="is_cod" t-value="doc.shipment_mode == 'cod'"/>
                
                <div class="page" style="width: 100mm; min-height: 140mm; padding: 8mm; font-family: 'Inter', 'Helvetica', sans-serif; color: #000; border: 4px solid #000; border-radius: 15px; background: #fff; margin: 0 auto;">
                    
                    <!-- Header -->
                    <table style="width: 100%; margin-bottom: 8mm;">
                        <tr>
                            <td style="width: 40%; vertical-align: middle;">
                                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 20mm; max-width: 35mm;"/>
                            </td>
                            <td style="width: 60%; text-align: right; vertical-align: middle;">
                                <div style="font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: #666;">Orden de Entrega</div>
                                <div style="font-size: 24px; font-weight: 900; margin-top: -2px;" t-field="doc.name"/>
                            </td>
                        </tr>
                    </table>

                    <!-- Destination -->
                    <div style="background: #000; color: #fff; padding: 4px 12px; border-radius: 6px; font-size: 10px; font-weight: 800; display: inline-block; margin-bottom: 5px; text-transform: uppercase;">
                        Entregar a:
                    </div>
                    <div style="margin-bottom: 8mm;">
                        <div style="font-size: 28px; font-weight: 900; line-height: 1.1; text-transform: uppercase;" t-field="doc.partner_id.name"/>
                        <div style="font-size: 18px; font-weight: 700; color: #333; margin-top: 5px;">
                            <span t-field="doc.partner_id.phone or doc.partner_id.mobile"/>
                        </div>
                    </div>

                    <!-- Address Box -->
                    <div style="border: 2px solid #000; border-radius: 10px; padding: 12px; margin-bottom: 5mm; background: #f9f9f9;">
                        <div style="font-size: 10px; font-weight: 800; text-transform: uppercase; color: #666; margin-bottom: 5px;">Dirección de Entrega:</div>
                        <div style="font-size: 14px; font-weight: 600; line-height: 1.3;" t-field="doc.partner_id.contact_address"/>
                    </div>

                    <!-- Customer Notes -->
                    <t t-if="doc.note or (shipment and shipment.customer_note)">
                        <div style="margin-bottom: 8mm; font-size: 11px; font-style: italic; color: #444; border-left: 3px solid #ccc; padding-left: 8px;">
                            <strong>Instrucciones:</strong> <span t-esc="doc.note or shipment.customer_note"/>
                        </div>
                    </t>

                    <!-- COD BLOCK (HIGHLIGHTED) -->
                    <t t-if="is_cod">
                        <div style="background: #FFD100; color: #000; border: 3px solid #000; border-radius: 12px; padding: 15px; text-align: center; margin-bottom: 10mm;">
                            <div style="font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">💰 COBRAR EN DESTINO 💰</div>
                            <div style="font-size: 36px; font-weight: 900; letter-spacing: -1px;">
                                <span t-esc="doc.amount_total" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <div style="background: #dcfce7; color: #166534; border: 2px solid #166534; border-radius: 12px; padding: 10px; text-align: center; margin-bottom: 10mm;">
                            <div style="font-size: 18px; font-weight: 900; text-transform: uppercase;">✓ PAGADO</div>
                        </div>
                    </t>

                    <!-- QR and Barcode -->
                    <table style="width: 100%; border-top: 2px dashed #ccc; padding-top: 8mm;">
                        <tr>
                            <td style="width: 50%; vertical-align: top;">
                                <t t-if="shipment and shipment.messenger_portal_url">
                                    <div style="font-size: 9px; font-weight: 800; color: #666; margin-bottom: 5px; text-transform: uppercase;">Escanear para Gestionar:</div>
                                    <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=150&amp;height=150' % (shipment.messenger_portal_url)" style="width: 35mm; height: 35mm;"/>
                                </t>
                            </td>
                            <td style="width: 50%; text-align: right; vertical-align: bottom;">
                                <img t-att-src="'/report/barcode/?barcode_type=Code128&amp;value=%s&amp;width=400&amp;height=100' % (doc.name)" style="width:45mm; height:12mm; margin-bottom: 10px;"/>
                                <div style="font-size: 9px; font-weight: 700; color: #999;">
                                    Generado por RENACE Portal
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
