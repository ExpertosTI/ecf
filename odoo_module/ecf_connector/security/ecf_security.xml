<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_ecf" model="ir.module.category">
        <field name="name">e-CF DGII</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_ecf_user" model="res.groups">
        <field name="name">Usuario e-CF</field>
        <field name="category_id" ref="module_category_ecf"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>

    <record id="group_ecf_manager" model="res.groups">
        <field name="name">Administrador e-CF</field>
        <field name="category_id" ref="module_category_ecf"/>
        <field name="implied_ids" eval="[(4, ref('group_ecf_user'))]"/>
    </record>
</odoo>
