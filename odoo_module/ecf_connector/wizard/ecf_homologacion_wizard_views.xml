<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ecf_homologacion_wizard_view_form" model="ir.ui.view">
        <field name="name">ecf.homologacion.wizard.form</field>
        <field name="model">ecf.homologacion.wizard</field>
        <field name="arch" type="xml">
            <form string="Homologación / Certificación DGII">
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom: 20px;">
                        <h4 class="alert-heading">Cargador de Set de Pruebas de la DGII</h4>
                        <p style="margin-bottom: 0;">
                            Sube el archivo Excel (<code>.xlsx</code>) descargado directamente desde el portal de certificación de la DGII (Paso 2).
                            El sistema creará automáticamente los 26 borradores de facturas con los clientes, productos, tasas de ITBIS y montos correspondientes.
                        </p>
                    </div>
                    <group>
                        <field name="xlsx_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_importar_set_pruebas" type="object"
                            string="Importar y Generar Facturas" class="btn-primary"
                            icon="fa-upload"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ecf_homologacion_wizard" model="ir.actions.act_window">
        <field name="name">Cargar Set de Pruebas DGII</field>
        <field name="model">ecf.homologacion.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menú bajo el menú raíz de e-CF -->
    <menuitem id="menu_ecf_homologacion_wizard"
              name="Set de Pruebas DGII"
              parent="ecf_menu_root"
              action="action_ecf_homologacion_wizard"
              sequence="50"/>
</odoo>
