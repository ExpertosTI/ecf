<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- ══════════════════════════════════════════════════════════════
         POS RECEIPT DGII e-CF
         Hereda el ticket estándar del POS para inyectar datos e-CF
         ══════════════════════════════════════════════════════════════ -->

    <t t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('receipt-header')]" position="after">
            <t t-if="props.data.ecf_ncf">
                <div class="pos-receipt-contact ecf-header" style="text-align:center; font-weight: bold; border-top: 1px dashed black; padding-top: 5px;">
                    <div>COMPROBANTE FISCAL ELECTRÓNICO</div>
                    <div class="ecf-ncf" style="font-size: 1.2em; margin-top: 3px;">
                        NCF: <t t-esc="props.data.ecf_ncf"/>
                    </div>
                </div>
            </t>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="after">
            <!-- Sección DGII al final del ticket -->
            <t t-if="props.data.ecf_ncf">
                <div class="ecf-footer" style="text-align: center; font-size: 0.8em; margin-top: 10px; border-top: 1px solid black; padding-top: 5px;">
                    <t t-if="props.data.ecf_cufe">
                        <div class="ecf-cufe" style="word-break: break-all;">
                            CUFE: <t t-esc="props.data.ecf_cufe.substring(0,20)"/>...
                        </div>
                    </t>

                    <!-- QR Pequeño (Small QR) para tickets térmicos -->
                    <t t-if="props.data.ecf_qr">
                        <div class="ecf-qr" style="margin-top: 5px;">
                            <img t-attf-src="/report/barcode/?barcode_type=QR&amp;value={{props.data.ecf_qr}}&amp;width=100&amp;height=100"
                                 style="width: 100px; height: 100px;"/>
                            <div style="font-size: 0.7em;">Verificar en DGII</div>
                        </div>
                    </t>

                    <div style="margin-top: 5px; font-weight: bold;">
                        <t t-esc="props.data.ecf_ambiente == 'produccion' ? 'PRODUCCIÓN' : 'CERTIFICACIÓN'"/>
                    </div>

                    <div class="ecf-legal" style="font-size: 0.7em; margin-top: 5px; line-height: 1.1;">
                        Este documento es una representación impresa de un e-CF.
                        SaaS: renace.tech
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>
