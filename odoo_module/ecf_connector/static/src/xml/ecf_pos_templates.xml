<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ecf_connector.EcfTypeButton" owl="1">
        <button class="control-button btn btn-light rounded-pill shadow-sm d-flex align-items-center px-3 py-2 border" 
                t-on-click="onClick"
                style="min-width: 180px; transition: all 0.2s ease;">
            <div class="d-flex flex-column align-items-start me-2">
                <span class="text-uppercase fw-bold small text-primary" style="font-size: 0.7rem; letter-spacing: 0.5px;">Tipo e-CF</span>
                <span class="fw-bold" style="font-size: 0.9rem; color: #1e293b;">
                    <t t-esc="currentTypeName"/>
                </span>
            </div>
            <i class="oi oi-chevron-down ms-auto text-muted" style="font-size: 0.8rem;"></i>
        </button>
    </t>

    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <EcfTypeButton />
        </xpath>
    </t>
</templates>
