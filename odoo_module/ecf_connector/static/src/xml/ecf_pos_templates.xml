<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ecf_connector.EcfTypeButton" owl="1">
        <div class="ecf-pos-controls-wrapper w-100 px-1 mt-1">
            <button class="control-button btn btn-light w-100 rounded-2 shadow-sm d-flex align-items-center justify-content-between px-2 py-1 border" 
                    t-on-click="onClick"
                    style="transition: all 0.2s ease; background: #fff; border-color: #e2e8f0; min-height: 32px; height: 32px;">
                
                <div class="d-flex align-items-center">
                    <span class="fw-medium" style="font-size: 0.75rem; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <t t-esc="currentTypeName"/>
                    </span>
                </div>

                <div class="ms-1">
                    <i class="oi oi-chevron-down text-muted" style="font-size: 0.5rem;"></i>
                </div>
            </button>
        </div>

    </t>

    <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('leftpane')]" position="inside">
            <EcfTypeButton />
        </xpath>
    </t>
</templates>
