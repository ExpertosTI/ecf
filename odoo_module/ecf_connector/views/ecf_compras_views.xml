<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecf_compra_recibida_list" model="ir.ui.view">
        <field name="name">ecf.compra.recibida.list</field>
        <field name="model">ecf.compra.recibida</field>
        <field name="arch" type="xml">
            <list string="e-CF Recibidas (Compras)" decoration-info="estado_odoo == 'nueva'" decoration-success="estado_odoo == 'procesada'" decoration-danger="estado_odoo == 'error'">
                <field name="fecha_comprobante"/>
                <field name="ncf"/>
                <field name="rnc_proveedor"/>
                <field name="nombre_proveedor"/>
                <field name="total_monto" sum="Total"/>
                <field name="itbis_facturado" sum="Total ITBIS"/>
                <field name="estado_comercial" widget="badge" decoration-success="estado_comercial == 'aprobado'" decoration-danger="estado_comercial == 'rechazado'" decoration-info="estado_comercial == 'pendiente'"/>
                <field name="estado_odoo" widget="badge" decoration-info="estado_odoo == 'nueva'" decoration-success="estado_odoo == 'procesada'" decoration-danger="estado_odoo == 'error'"/>
                <field name="move_id" widget="many2one_clickable"/>
                <field name="ambiente" optional="hide"/>
                <header>
                    <button name="action_sync_from_saas" string="📥 Sincronizar desde SaaS" type="object" class="btn-primary"/>
                </header>
            </list>
        </field>
    </record>

    <record id="view_ecf_compra_recibida_form" model="ir.ui.view">
        <field name="name">ecf.compra.recibida.form</field>
        <field name="model">ecf.compra.recibida</field>
        <field name="arch" type="xml">
            <form string="e-CF Recibida">
                <header>
                    <button name="action_crear_factura" string="Crear Factura" type="object" class="oe_highlight" invisible="estado_odoo == 'procesada'"/>
                    <button name="action_aprobar_comercial" string="Aprobación Comercial" type="object" class="btn-success" invisible="estado_comercial != 'pendiente'"/>
                    <button name="action_rechazar_comercial" string="Rechazo Comercial" type="object" class="btn-danger" invisible="estado_comercial != 'pendiente'"/>
                    <button name="action_registrar_pago" string="Notificar Pago" type="object" invisible="not move_id or not fecha_pago"/>
                    <button name="action_sincronizar_dgii" string="Sincronizar DGII" type="object"/>
                    <field name="estado_comercial" widget="statusbar" statusbar_visible="pendiente,aprobado,rechazado"/>
                    <field name="estado_odoo" widget="statusbar" statusbar_visible="nueva,procesada,error"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_factura" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="not move_id">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Factura</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="ncf" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos del e-CF">
                            <field name="cufe" readonly="1"/>
                            <field name="tipo_ecf_nombre" string="Tipo e-CF"/>
                            <field name="fecha_comprobante" readonly="1"/>
                            <field name="fecha_pago"/>
                            <field name="ambiente" readonly="1"/>
                        </group>
                        <group string="Proveedor">
                            <field name="rnc_proveedor" readonly="1"/>
                            <field name="nombre_proveedor" readonly="1"/>
                            <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'supplier'}"/>
                            <field name="motivo_rechazo" invisible="estado_comercial != 'rechazado'" readonly="estado_comercial == 'rechazado'"/>
                        </group>
                    </group>
                    <group string="Totales">
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="monto_bienes" widget="monetary" readonly="1"/>
                            <field name="monto_servicios" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="itbis_facturado" widget="monetary" readonly="1"/>
                            <field name="total_monto" widget="monetary" readonly="1" class="oe_subtotal_footer_separator"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Información Adicional" name="info_extra">
                            <group>
                                <field name="itbis_retenido" widget="monetary" readonly="1"/>
                                <field name="isr_retencion" widget="monetary" readonly="1"/>
                                <field name="move_id" readonly="1"/>
                                <field name="error_mensaje" invisible="not error_mensaje"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ecf_compra_recibida_search" model="ir.ui.view">
        <field name="name">ecf.compra.recibida.search</field>
        <field name="model">ecf.compra.recibida</field>
        <field name="arch" type="xml">
            <search string="Buscar e-CF Recibidas">
                <field name="ncf"/>
                <field name="rnc_proveedor"/>
                <field name="nombre_proveedor"/>
                <filter string="Nuevas" name="new" domain="[('estado_odoo', '=', 'nueva')]"/>
                <filter string="Procesadas" name="processed" domain="[('estado_odoo', '=', 'procesada')]"/>
                <filter string="Con Error" name="error" domain="[('estado_odoo', '=', 'error')]"/>
                <separator/>
                <filter string="Fecha Comprobante" name="date" date="fecha_comprobante"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Proveedor" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Estado" name="group_state" context="{'group_by': 'estado_odoo'}"/>
                    <filter string="Fecha" name="group_date" context="{'group_by': 'fecha_comprobante'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ecf_compra_recibida" model="ir.actions.act_window">
        <field name="name">e-CF Recibidas (Compras)</field>
        <field name="res_model">ecf.compra.recibida</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ecf_compra_recibida_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aquí aparecerán las facturas que tus proveedores emiten vía e-CF.
            </p>
            <p>
                El sistema las descarga automáticamente de la DGII y te permite crear la factura de proveedor en un clic.
            </p>
        </field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_ecf_compra_recibida"
              name="e-CF Recibidas"
              parent="account.menu_finance_payables"
              action="action_ecf_compra_recibida"
              sequence="15"/>
</odoo>
