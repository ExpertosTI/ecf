<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════
         DASHBOARD e-CF — Vista Kanban con KPIs
         ══════════════════════════════════════════════ -->

    <!-- Acción del Dashboard -->
    <record id="ecf_dashboard_action" model="ir.actions.act_window">
        <field name="name">Dashboard e-CF</field>
        <field name="res_model">ecf.log</field>
        <field name="view_mode">kanban,list,graph</field>
        <field name="context">{'search_default_group_by_estado': 1}</field>
    </record>

    <!-- Vista Kanban: Estilo Premium con KPIs -->
    <record id="ecf_log_kanban_view" model="ir.ui.view">
        <field name="name">ecf.log.kanban</field>
        <field name="model">ecf.log</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado" 
                    class="o_kanban_small_column" 
                    group_create="false" 
                    sample="1">
                <field name="ncf"/>
                <field name="estado"/>
                <field name="move_id"/>
                <field name="tipo_ecf"/>
                <field name="cufe"/>
                <field name="approved_at"/>
                <field name="ambiente"/>
                <field name="create_date"/>
                <field name="error_msg"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click shadow-sm border-0 rounded-lg">
                            <div class="oe_kanban_content p-2">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex flex-column">
                                        <strong class="text-primary fs-5"><field name="ncf"/></strong>
                                        <span class="badge text-bg-light border small w-auto">Tipo <field name="tipo_ecf"/></span>
                                    </div>
                                    <span t-if="record.estado.raw_value" 
                                          t-attf-class="badge rounded-pill #{record.estado.raw_value == 'aprobado' and 'text-bg-success' or record.estado.raw_value == 'rechazado' and 'text-bg-danger' or 'text-bg-warning'}">
                                        <t t-esc="record.estado.value"/>
                                    </span>
                                </div>
                                
                                <div class="o_kanban_record_body my-2">
                                    <div class="text-muted small mb-1">Factura Odoo:</div>
                                    <strong><field name="move_id"/></strong>
                                </div>

                                <div class="o_kanban_record_bottom border-top pt-2 mt-2 d-flex justify-content-between align-items-center">
                                    <div class="oe_kanban_bottom_left text-muted x-small">
                                        <i class="fa fa-calendar me-1"/> <field name="create_date" widget="date"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <span t-if="record.ambiente.raw_value"
                                              t-attf-class="badge rounded-pill #{record.ambiente.raw_value == 'produccion' and 'text-bg-info' or 'text-bg-secondary'} px-2 py-1" 
                                              style="font-size: 0.65rem; text-transform: uppercase;">
                                            <t t-esc="record.ambiente.raw_value"/>
                                        </span>
                                    </div>
                                </div>
                                
                                <div t-if="record.error_msg.raw_value" class="mt-2">
                                    <div class="alert alert-danger p-2 mb-0 x-small" style="line-height: 1.2;">
                                        <i class="fa fa-exclamation-triangle me-1"/> <field name="error_msg"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista Gráfico: barras por estado del mes -->
    <record id="ecf_log_graph_view" model="ir.ui.view">
        <field name="name">ecf.log.graph</field>
        <field name="model">ecf.log</field>
        <field name="arch" type="xml">
            <graph string="e-CF por Estado" type="bar">
                <field name="estado" type="row"/>
                <field name="create_date" interval="month" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Vista de búsqueda con filtros predefinidos -->
    <record id="ecf_log_search_view" model="ir.ui.view">
        <field name="name">ecf.log.search</field>
        <field name="model">ecf.log</field>
        <field name="arch" type="xml">
            <search string="Buscar e-CF">
                <field name="ncf" string="NCF"/>
                <field name="move_id" string="Factura"/>
                <filter string="Aprobados" name="aprobados" domain="[('estado','=','aprobado')]"/>
                <filter string="Rechazados" name="rechazados" domain="[('estado','=','rechazado')]"/>
                <filter string="Condicionados" name="condicionados" domain="[('estado','=','condicionado')]"/>
                <filter string="Pendientes" name="pendientes" domain="[('estado','=','pendiente')]"/>
                <filter string="Anulados" name="anulados" domain="[('estado','in',['anulado','anulacion_fallida'])]"/>
                <separator/>
                <filter string="Certificación" name="certificacion" domain="[('ambiente','=','certificacion')]"/>
                <filter string="Producción" name="produccion" domain="[('ambiente','=','produccion')]"/>
                <separator/>
                <filter string="Este mes" name="este_mes"
                        domain="[('create_date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_estado" string="Estado" context="{'group_by': 'estado'}"/>
                    <filter name="group_by_tipo" string="Tipo e-CF" context="{'group_by': 'tipo_ecf'}"/>
                    <filter name="group_by_ambiente" string="Ambiente" context="{'group_by': 'ambiente'}"/>
                    <filter name="group_by_month" string="Mes" context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Menú Dashboard -->
    <menuitem id="ecf_menu_dashboard"
              name="Dashboard e-CF"
              parent="ecf_connector.ecf_menu_root"
              action="ecf_dashboard_action"
              sequence="1"/>

</odoo>
