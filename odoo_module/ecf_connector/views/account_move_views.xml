<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Vista de formulario de factura — sección e-CF actualizada
         ============================================================ -->
    <record id="view_move_form_ecf" model="ir.ui.view">
        <field name="name">account.move.form.ecf</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Botones de acción en la cabecera -->
            <xpath expr="//header" position="inside">
                <!-- Emitir e-CF: estado borrador con tipo definido -->
                <button name="action_emitir_ecf"
                        string="⚡ Emitir e-CF"
                        type="object"
                        class="btn-primary"
                        invisible="
                            not ecf_tipo_id or
                            ecf_estado in ('enviado','aprobado','condicionado','anulacion_pendiente','anulado') or
                            ecf_pendiente_conciliacion or
                            ecf_modo == 'excento'
                        "
                        groups="ecf_connector.group_ecf_user"/>

                <!-- Emitir e-CF: pago conciliado, listo -->
                <button name="action_emitir_ecf"
                        string="✅ Emitir e-CF — Pago Recibido"
                        type="object"
                        class="btn-primary"
                        invisible="not ecf_listo_para_emitir"
                        groups="ecf_connector.group_ecf_user"/>

                <!-- Consultar estado DGII -->
                <button name="action_consultar_estado_ecf"
                        string="↻ Actualizar Estado"
                        type="object"
                        class="btn-secondary"
                        invisible="not ecf_ncf"
                        groups="ecf_connector.group_ecf_user"/>

                <!-- Anular e-CF -->
                <button name="action_anular_ecf"
                        string="🚫 Anular e-CF"
                        type="object"
                        class="btn-secondary"
                        invisible="ecf_estado not in ('aprobado', 'condicionado')"
                        groups="ecf_connector.group_ecf_user"/>
            </xpath>

            <!-- Badge de estado después del campo state -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="ecf_estado"
                       widget="ecf_status"
                       invisible="not ecf_estado"/>
            </xpath>

            <!-- Banner informativo de e-CF bajo la barra de botones -->
            <xpath expr="//sheet" position="before">
                <!-- NCF aprobado: mostrar badge verde con NCF -->
                <div class="alert alert-success d-flex align-items-center gap-2"
                     role="alert"
                     invisible="ecf_estado != 'aprobado'"
                     style="margin: 0; border-radius: 0; border-left: none; border-right: none;">
                    <strong>✅ e-CF Aprobado DGII</strong>
                    <span>·</span>
                    <span>NCF: <field name="ecf_ncf" readonly="1" nolabel="1" style="display:inline; font-weight:700;"/></span>
                </div>
                <!-- Rechazado: banner rojo -->
                <div class="alert alert-danger"
                     role="alert"
                     invisible="ecf_estado != 'rechazado'"
                     style="margin: 0; border-radius: 0; border-left: none; border-right: none;">
                    <strong>❌ e-CF Rechazado por la DGII</strong> — Revisa la pestaña "e-CF DGII" para ver el motivo y corregir.
                </div>
                <!-- Condicionado: advertencia amarilla -->
                <div class="alert alert-warning"
                     role="alert"
                     invisible="ecf_estado != 'condicionado'"
                     style="margin: 0; border-radius: 0; border-left: none; border-right: none;">
                    <strong>⚠️ e-CF Condicionado</strong> — Aprobado con observaciones. NCF: <field name="ecf_ncf" readonly="1" nolabel="1" style="display:inline; font-weight:700;"/>
                </div>
                <!-- Sin tipo e-CF definido en factura confirmada -->
                <div class="alert alert-warning"
                     role="alert"
                     invisible="state != 'posted' or ecf_tipo_id or move_type not in ('out_invoice','out_refund')"
                     style="margin: 0; border-radius: 0; border-left: none; border-right: none;">
                    <strong>⚠️ Sin tipo e-CF.</strong> Ve a la pestaña <em>"e-CF DGII"</em> y selecciona el tipo de comprobante para poder emitir.
                </div>
            </xpath>

            <!-- Pestaña dedicada al e-CF -->
            <xpath expr="//notebook" position="inside">
                <page string="e-CF DGII"
                      name="page_ecf"
                      invisible="move_type not in ('out_invoice', 'out_refund')">
                    <group>
                        <group string="Comprobante Fiscal">
                            <field name="ecf_tipo_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="ecf_modo"
                                   readonly="state != 'draft'"/>
                            <field name="ecf_ncf" readonly="1"/>
                            <field name="ecf_estado" readonly="1" widget="ecf_status"/>
                            <field name="partner_rnc" readonly="1" string="RNC/Cédula cliente"/>
                        </group>
                        <group string="Estado Conciliación">
                            <field name="ecf_pendiente_conciliacion" readonly="1"/>
                            <field name="ecf_listo_para_emitir" readonly="1"/>
                        </group>
                    </group>
                    <group string="Validación DGII" invisible="not ecf_ncf">
                        <group>
                            <field name="ecf_cufe" readonly="1"/>
                        </group>
                        <group>
                            <field name="ecf_qr" readonly="1" widget="text"/>
                        </group>
                    </group>

                    <!-- Alerta diferido pendiente -->
                    <div class="alert alert-warning" role="alert"
                         invisible="not ecf_pendiente_conciliacion">
                        <strong>⏳ Pendiente de conciliación:</strong>
                        Esta factura está en modo diferido. El e-CF se podrá emitir
                        cuando el pago sea registrado y conciliado completamente.
                    </div>

                    <!-- Alerta listo para emitir -->
                    <div class="alert alert-success" role="alert"
                         invisible="not ecf_listo_para_emitir">
                        <strong>✅ Lista para emitir:</strong>
                        El pago fue recibido. Use el botón
                        <em>"Emitir e-CF (Pago Recibido)"</em> para generar el comprobante.
                    </div>

                    <separator string="Historial de e-CF"/>
                    <field name="ecf_log_ids" readonly="1">
                        <list>
                            <field name="create_date" string="Fecha"/>
                            <field name="ncf"/>
                            <field name="tipo_ecf" string="Tipo"/>
                            <field name="estado"
                                   decoration-success="estado == 'aprobado'"
                                   decoration-danger="estado == 'rechazado'"
                                   decoration-warning="estado in ('condicionado','anulacion_pendiente')"
                                   decoration-muted="estado in ('pendiente','anulado')"/>
                            <field name="cufe"/>
                            <field name="ambiente"/>
                            <field name="approved_at" string="Aprobado DGII"/>
                            <field name="error_msg"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ============================================================
         Vista de lista de facturas — columnas NCF y estado + filtros
         ============================================================ -->
    <record id="view_move_list_ecf" model="ir.ui.view">
        <field name="name">account.move.list.ecf</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list//field[@name='name']" position="after">
                <field name="ecf_ncf" optional="show" string="NCF"/>
                <field name="ecf_estado" optional="show" string="Estado e-CF"
                       decoration-success="ecf_estado == 'aprobado'"
                       decoration-danger="ecf_estado == 'rechazado'"
                       decoration-warning="ecf_estado in ('condicionado','anulacion_pendiente')"
                       decoration-muted="ecf_estado == 'pendiente'"/>
                <field name="ecf_listo_para_emitir" optional="show" string="Listo e-CF"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         Vista de búsqueda de facturas — filtros rápidos e-CF
         ============================================================ -->
    <record id="view_move_search_ecf" model="ir.ui.view">
        <field name="name">account.move.search.ecf</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group" position="before">
                <separator/>
                <filter string="✅ e-CF Aprobados"
                        name="ecf_aprobados"
                        domain="[('ecf_estado','=','aprobado')]"/>
                <filter string="⚡ Sin emitir"
                        name="ecf_sin_emitir"
                        domain="[('ecf_tipo_id','!=',False),('ecf_estado','in',[False,''])]"/>
                <filter string="⏳ Listos para emitir"
                        name="ecf_listos"
                        domain="[('ecf_listo_para_emitir','=',True)]"/>
                <filter string="❌ Rechazados"
                        name="ecf_rechazados"
                        domain="[('ecf_estado','=','rechazado')]"/>
                <filter string="⚠️ Condicionados"
                        name="ecf_condicionados"
                        domain="[('ecf_estado','=','condicionado')]"/>
                <separator/>
                <filter string="🔍 Sin tipo e-CF"
                        name="ecf_sin_tipo"
                        domain="[('move_type','in',['out_invoice','out_refund']),('state','=','posted'),('ecf_tipo_id','=',False)]"/>
                <group expand="0" string="Agrupar por e-CF">
                    <filter string="Estado e-CF"
                            name="group_ecf_estado"
                            context="{'group_by': 'ecf_estado'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>

