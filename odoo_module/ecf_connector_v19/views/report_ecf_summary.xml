<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_ecf_summary" model="ir.actions.report">
        <field name="name">Reporte Consolidado e-CF</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ecf_connector_v19.report_ecf_summary_template</field>
        <field name="report_file">ecf_connector_v19.report_ecf_summary_template</field>
        <field name="print_report_name">'Reporte_eCF'</field>
    </record>

    <template id="report_ecf_summary_template">
        <t t-call="web.html_container">
            <t t-set="total_untaxed" t-value="0.0"/>
            <t t-set="total_tax" t-value="0.0"/>
            <t t-set="total_all" t-value="0.0"/>
            
            <t t-call="web.external_layout">
                <div class="page" style="font-family: 'Helvetica';">
                    <div class="row mb-4 align-items-center">
                        <div class="col-4">
                            <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 80px;" alt="Logo"/>
                        </div>
                        <div class="col-8 text-end">
                            <h2 style="color: #0087ff; font-weight: bold; margin: 0;">Reporte Consolidado e-CF</h2>
                            <p class="text-muted mb-0">Resumen Fiscal DGII - Auditoría Premium</p>
                        </div>
                    </div>

                    <table class="table table-sm mt-4">
                        <thead style="background-color: #0f172a; color: white;">
                            <tr>
                                <th class="p-2">NCF / Documento</th>
                                <th class="p-2">Fecha</th>
                                <th class="p-2">Cliente / Proveedor</th>
                                <th class="p-2 text-end">Base Imponible</th>
                                <th class="p-2 text-end">ITBIS</th>
                                <th class="p-2 text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="o">
                                <t t-set="total_untaxed" t-value="total_untaxed + (o.amount_untaxed or 0.0)"/>
                                <t t-set="total_tax" t-value="total_tax + (o.amount_tax or 0.0)"/>
                                <t t-set="total_all" t-value="total_all + (o.amount_total or 0.0)"/>
                                <tr>
                                    <td class="p-2 fw-bold"><span t-esc="o.l10n_latam_document_number or o.name"/></td>
                                    <td class="p-2"><span t-field="o.invoice_date"/></td>
                                    <td class="p-2"><span t-field="o.partner_id.name"/></td>
                                    <td class="p-2 text-end"><span t-esc="'{:,.2f}'.format(o.amount_untaxed)"/></td>
                                    <td class="p-2 text-end"><span t-esc="'{:,.2f}'.format(o.amount_tax)"/></td>
                                    <td class="p-2 text-end fw-bold">RD$ <span t-esc="'{:,.2f}'.format(o.amount_total)"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="row justify-content-end mt-4">
                        <div class="col-5">
                            <table class="table table-sm border">
                                <tr>
                                    <td class="p-2"><strong>Total Base Imponible:</strong></td>
                                    <td class="p-2 text-end">RD$ <t t-esc="'{:,.2f}'.format(total_untaxed)"/></td>
                                </tr>
                                <tr>
                                    <td class="p-2"><strong>Total ITBIS:</strong></td>
                                    <td class="p-2 text-end text-success">RD$ <t t-esc="'{:,.2f}'.format(total_tax)"/></td>
                                </tr>
                                <tr style="background-color: #0f172a; color: white;">
                                    <td class="p-2"><strong>TOTAL GENERAL:</strong></td>
                                    <td class="p-2 text-end fw-bold" style="font-size: 1.2rem;">RD$ <t t-esc="'{:,.2f}'.format(total_all)"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="footer text-center small text-muted mt-5" style="border-top: 1px solid #dee2e6; padding-top: 10px;">
                        Reporte Generado Automáticamente por Renace e-CF Connector
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
