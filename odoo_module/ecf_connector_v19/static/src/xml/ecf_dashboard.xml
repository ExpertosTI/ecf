<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ecf_connector_v19.EcfDashboard" owl="1">
        <div class="ecf-dash h-100 overflow-auto">
            <div class="ecf-dash__inner">

                <!-- Header -->
                <header class="ecf-dash__header">
                    <div class="ecf-dash__title-block">
                        <p class="ecf-dash__brand">RENECF</p>
                        <h1 class="ecf-dash__title">Panel de Control</h1>
                        <p class="ecf-dash__subtitle">Monitoreo fiscal e-CF · DGII</p>
                    </div>

                    <div class="ecf-dash__actions">
                        <div t-attf-class="ecf-status ecf-status--{{ state.saas_status }}">
                            <span class="ecf-status__dot"/>
                            <span t-if="state.saas_status === 'online'">Conectado</span>
                            <span t-elif="state.saas_status === 'warning'">Configurar</span>
                            <span t-elif="state.saas_status === 'offline'">Desconectado</span>
                            <span t-else="">Verificando…</span>
                            <span t-if="state.saas.reason" class="ecf-status__hint" t-esc="state.saas.reason"/>
                            <span t-elif="state.saas.latency_ms" class="ecf-status__hint">
                                <t t-esc="state.saas.latency_ms"/> ms
                            </span>
                        </div>

                        <div class="ecf-date-range">
                            <i class="fa fa-calendar-o" title="Periodo"/>
                            <input type="date" t-model="state.date_from" t-on-change="loadData"/>
                            <span class="ecf-date-range__sep">—</span>
                            <input type="date" t-model="state.date_to" t-on-change="loadData"/>
                        </div>

                        <div class="ecf-quick">
                            <button type="button" class="ecf-chip" t-on-click="() => this.setQuickDate('today')">Hoy</button>
                            <button type="button" class="ecf-chip" t-on-click="() => this.setQuickDate('week')">Semana</button>
                            <button type="button" class="ecf-chip" t-on-click="() => this.setQuickDate('month')">Mes</button>
                        </div>

                        <button type="button" class="ecf-btn ecf-btn--ghost" t-on-click="loadData" title="Actualizar">
                            <i class="fa fa-refresh"/>
                        </button>
                        <button type="button" class="ecf-btn ecf-btn--solid" t-on-click="openHistory">
                            <i class="fa fa-list-ul"/> Historial
                        </button>
                    </div>
                </header>

                <!-- KPIs -->
                <section class="ecf-kpi-grid">
                    <article class="ecf-kpi ecf-kpi--accent">
                        <div class="ecf-kpi__icon"><i class="fa fa-line-chart"/></div>
                        <div>
                            <p class="ecf-kpi__label">Total facturado</p>
                            <p class="ecf-kpi__value">RD$ <t t-esc="state.stats.total_amount?.toLocaleString() || '0'"/></p>
                        </div>
                    </article>
                    <article class="ecf-kpi">
                        <div class="ecf-kpi__icon"><i class="fa fa-file-text-o"/></div>
                        <div>
                            <p class="ecf-kpi__label">Comprobantes</p>
                            <p class="ecf-kpi__value"><t t-esc="state.stats.total_count || '0'"/></p>
                        </div>
                    </article>
                    <article class="ecf-kpi">
                        <div class="ecf-kpi__icon ecf-kpi__icon--ok"><i class="fa fa-check"/></div>
                        <div>
                            <p class="ecf-kpi__label">Aprobados</p>
                            <p class="ecf-kpi__value"><t t-esc="state.stats.stats_estado?.aprobado || '0'"/></p>
                        </div>
                    </article>
                    <article class="ecf-kpi">
                        <div class="ecf-kpi__icon ecf-kpi__icon--bad"><i class="fa fa-times"/></div>
                        <div>
                            <p class="ecf-kpi__label">Rechazados</p>
                            <p class="ecf-kpi__value"><t t-esc="state.stats.stats_estado?.rechazado || '0'"/></p>
                        </div>
                    </article>
                </section>

                <!-- Reportes -->
                <section class="ecf-section">
                    <div class="ecf-section__head">
                        <h2>Reportes fiscales</h2>
                        <span>Periodo filtrado</span>
                    </div>
                    <div class="ecf-report-grid">
                        <article class="ecf-report">
                            <div class="ecf-report__top">
                                <span class="ecf-report__glyph"><i class="fa fa-shopping-cart"/></span>
                                <div>
                                    <h3>606</h3>
                                    <p>Compras</p>
                                </div>
                            </div>
                            <p class="ecf-report__amount">RD$ <t t-esc="state.fiscal.compras?.total.toLocaleString() || '0'"/></p>
                            <p class="ecf-report__meta"><t t-esc="state.fiscal.compras?.count || 0"/> registros</p>
                            <button type="button" class="ecf-btn ecf-btn--soft" t-on-click="() => this.openReportDetail('606')">
                                Ver detalle
                            </button>
                            <div class="ecf-export">
                                <button type="button" t-on-click="() => this.exportReport('606', 'txt')">TXT</button>
                                <button type="button" t-on-click="() => this.exportReport('606', 'excel')">Excel</button>
                                <button type="button" t-on-click="() => this.exportReport('606', 'pdf')">PDF</button>
                            </div>
                        </article>

                        <article class="ecf-report">
                            <div class="ecf-report__top">
                                <span class="ecf-report__glyph"><i class="fa fa-tag"/></span>
                                <div>
                                    <h3>607</h3>
                                    <p>Ventas e-CF</p>
                                </div>
                            </div>
                            <p class="ecf-report__amount">RD$ <t t-esc="state.fiscal.ventas?.total.toLocaleString() || '0'"/></p>
                            <p class="ecf-report__meta"><t t-esc="state.fiscal.ventas?.count || 0"/> emitidos</p>
                            <button type="button" class="ecf-btn ecf-btn--soft" t-on-click="() => this.openReportDetail('607')">
                                Ver detalle
                            </button>
                            <div class="ecf-export">
                                <button type="button" t-on-click="() => this.exportReport('607', 'txt')">TXT</button>
                                <button type="button" t-on-click="() => this.exportReport('607', 'excel')">Excel</button>
                                <button type="button" t-on-click="() => this.exportReport('607', 'pdf')">PDF</button>
                            </div>
                        </article>

                        <article class="ecf-report">
                            <div class="ecf-report__top">
                                <span class="ecf-report__glyph"><i class="fa fa-ban"/></span>
                                <div>
                                    <h3>608</h3>
                                    <p>Anulaciones</p>
                                </div>
                            </div>
                            <p class="ecf-report__amount"><t t-esc="state.stats.stats_estado?.rechazado || 0"/></p>
                            <p class="ecf-report__meta">Anulados / rechazados</p>
                            <button type="button" class="ecf-btn ecf-btn--soft" t-on-click="printReport608">
                                Ver anulaciones
                            </button>
                        </article>
                    </div>
                </section>

                <!-- Charts + activity -->
                <section class="ecf-split">
                    <article class="ecf-panel ecf-panel--wide">
                        <div class="ecf-section__head">
                            <h2>Volumen de emisión</h2>
                        </div>
                        <div class="ecf-chart">
                            <canvas t-ref="chartVolume"/>
                        </div>
                    </article>
                    <article class="ecf-panel">
                        <div class="ecf-section__head">
                            <h2>Estado de envío</h2>
                        </div>
                        <div class="ecf-chart">
                            <canvas t-ref="chartStatus"/>
                        </div>
                    </article>
                </section>

                <section class="ecf-split">
                    <article class="ecf-panel ecf-panel--wide">
                        <div class="ecf-section__head">
                            <h2>Actividad reciente</h2>
                        </div>
                        <div class="table-responsive">
                            <table class="ecf-table">
                                <thead>
                                    <tr>
                                        <th>NCF</th>
                                        <th>Cliente</th>
                                        <th>Monto</th>
                                        <th>Estado</th>
                                        <th>Fecha</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.stats.recent_logs || []" t-as="log" t-key="log.id">
                                        <tr t-on-click="() => this.openMove(log.move_id)">
                                            <td class="ecf-mono"><t t-esc="log.ncf"/></td>
                                            <td><t t-esc="log.cliente"/></td>
                                            <td>RD$ <t t-esc="log.monto.toLocaleString()"/></td>
                                            <td>
                                                <span t-attf-class="ecf-pill ecf-pill--{{ log.estado }}">
                                                    <t t-esc="log.estado"/>
                                                </span>
                                            </td>
                                            <td class="ecf-muted"><t t-esc="log.fecha"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <article class="ecf-panel ecf-panel--health">
                        <div class="ecf-section__head">
                            <h2>Salud técnica</h2>
                        </div>
                        <p class="ecf-health__score"><t t-esc="state.compliance.compliance_score || 0"/>%</p>
                        <div class="ecf-health__bar">
                            <div t-attf-style="width: {{ state.compliance.compliance_score || 0 }}%"/>
                        </div>
                        <ul class="ecf-health__list">
                            <t t-foreach="state.compliance.issues || []" t-as="issue" t-key="issue.msg">
                                <li>
                                    <i t-attf-class="fa {{ iconForIssue(issue.type) }}"/>
                                    <span t-esc="issue.msg"/>
                                </li>
                            </t>
                        </ul>
                    </article>
                </section>

                <!-- Report viewer -->
                <div t-if="state.show_report_viewer" class="ecf-modal">
                    <div class="ecf-modal__panel">
                        <div class="ecf-modal__head">
                            <div>
                                <h2>Reporte <t t-esc="state.current_report_type"/></h2>
                                <p>Detalle fiscal del periodo</p>
                            </div>
                            <button type="button" class="ecf-btn ecf-btn--ghost" t-on-click="() => state.show_report_viewer = false">
                                <i class="fa fa-times"/>
                            </button>
                        </div>
                        <div class="ecf-modal__body">
                            <table class="ecf-table">
                                <thead>
                                    <tr>
                                        <th>RNC</th>
                                        <th>NCF</th>
                                        <th>Fecha</th>
                                        <th>Cliente / Proveedor</th>
                                        <th class="text-end">Base</th>
                                        <th class="text-end">ITBIS</th>
                                        <th class="text-end">Total</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.report_details || []" t-as="row" t-key="row.id">
                                        <tr>
                                            <td class="ecf-mono"><t t-esc="row.rnc"/></td>
                                            <td class="ecf-mono"><t t-esc="row.ncf"/></td>
                                            <td><t t-esc="row.date"/></td>
                                            <td><t t-esc="row.partner"/></td>
                                            <td class="text-end">RD$ <t t-esc="row.base.toLocaleString()"/></td>
                                            <td class="text-end">RD$ <t t-esc="row.tax.toLocaleString()"/></td>
                                            <td class="text-end">RD$ <t t-esc="row.total.toLocaleString()"/></td>
                                            <td><t t-esc="row.status"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <div class="ecf-modal__foot">
                            <button type="button" class="ecf-btn ecf-btn--solid" t-on-click="() => this.exportReport(state.current_report_type, 'excel')">
                                Exportar Excel
                            </button>
                            <button type="button" class="ecf-btn ecf-btn--ghost" t-on-click="() => this.exportReport(state.current_report_type, 'pdf')">
                                PDF
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>
